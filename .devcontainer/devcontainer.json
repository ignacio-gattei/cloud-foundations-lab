{
  "name": "cloud-foundations-lab",
  "image": "mcr.microsoft.com/devcontainers/base:ubuntu-22.04",

  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {},
    "ghcr.io/devcontainers/features/python:1": { "version": "3.11" }
  },

  "postCreateCommand": "pip install -r requirements.txt && cp .env.example .env",

  "forwardPorts": [5432, 9000, 9001, 6379, 9092, 4566],
  "portsAttributes": {
    "5432": { "label": "PostgreSQL" },
    "9000": { "label": "MinIO API" },
    "9001": { "label": "MinIO Console" },
    "6379": { "label": "Redis" },
    "9092": { "label": "Redpanda" },
    "4566": { "label": "LocalStack" }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-azuretools.vscode-docker",
        "hashicorp.terraform",
        "mtxr.sqltools",
        "mtxr.sqltools-driver-pg"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python3",
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  }
}
